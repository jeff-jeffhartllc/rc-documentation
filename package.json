    "build:all": "npm run pdf:build:clean && npm run docx:build:clean"
  },
  "devDependencies": {
    "@mohtasham/md-to-docx": "^2.18.0",
    "chokidar": "^4.0.3",
    "md-to-pdf": "^5.2.5"
  }
}
