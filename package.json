{
  "name": "rc-documentation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "pdf:build": "node scripts/build-pdfs.mjs",
    "pdf:build:clean": "node scripts/build-pdfs.mjs --clean",
    "pdf:watch": "node scripts/build-pdfs.mjs --watch",
    "docx:build": "node scripts/build-docx.mjs",
